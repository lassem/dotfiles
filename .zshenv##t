# ~/.zshenv — sourced for ALL zsh sessions (interactive and non-interactive)
# Managed by yadm. Edit ~/.zshenv##t, then run `yadm alt` to regenerate.
# Keep this minimal — only what every zsh session needs.

# --- local overrides (secrets, machine-specific env) ---
[[ -f ~/.localrc ]] && source ~/.localrc

# --- common ---
export QUOTING_STYLE=literal
export HISTCONTROL=ignoreboth
export PAGER='bat --style=plain'
export MANPAGER='sh -c "col -bx | bat -l man -p"'

export GIT_PS1_SHOWCOLORHINTS=true

# cargo
[[ -f "$HOME/.cargo/env" ]] && . "$HOME/.cargo/env"

# --- macOS-specific ---
{% if yadm.os == "Darwin" %}
export JAVA_HOME=$(/usr/libexec/java_home -v 17)
export ANDROID_SDK_ROOT=~/Library/Android/sdk
export ANDROID_HOME=$ANDROID_SDK_ROOT
export CATALINA_HOME=~/.catalina
export VBCC=~/amiga/amiga_sdk/vbcc
export NDK_INC=~/amiga/amiga_sdk/NDK_3.9/Include/include_h
export GYP_GENERATORS='ninja'
export TTC_REPOS=~/src
export TTC_WEATHER=Oslo

export PATH=/usr/local/bin:/usr/local/sbin:$PATH
export PATH=/usr/local/opt/openssl/bin:$PATH
export PATH=$PATH:$ANDROID_HOME/tools
export PATH=$PATH:$ANDROID_HOME/platform-tools
export PATH=$PATH:$ANDROID_HOME/cmdline-tools/latest/bin
export PATH=$PATH:$VBCC/bin
export PATH=$PATH:$JAVA_HOME/bin
export PATH=$PATH:~/commodore/bin
export PATH=$PATH:~/src/depot_tools
{% endif %}
